{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "key": "development-v2",
        "paths": [".expo"]
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "key": "preview-v2",
        "paths": [".expo"]
      }
    },
    "production": {
      "autoIncrement": true,
      "cache": {
        "key": "production-v2",
        "paths": [".expo"]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
